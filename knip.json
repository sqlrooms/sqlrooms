{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  },
  "ignoreDependencies": ["identity-obj-proxy"],
  "ignore": [
    "python/**",
    "docs/**",
    "examples/app-builder/app-scaffolds/**",
    "apps/sqlrooms-cli-ui/app-scaffolds/get-started/**"
  ],
  "exclude": ["exports", "types", "duplicates"],
  "workspaces": {
    ".": {
      "entry": ["scripts/*.mjs"],
      "ignoreDependencies": [
        "@types/*",
        "@lerna-lite/*",
        "glob",
        "remove",
        "vitepress-plugin-llms",
        "typescript-language-server"
      ],
      "ignoreBinaries": ["madge", "uv"]
    },
    "packages/*": {
      "entry": ["src/index.{ts,tsx}"]
    },
    "packages/artifacts": {
      "ignoreDependencies": ["ts-jest"]
    },
    "packages/preset-jest": {
      "entry": ["*.js"],
      "ignoreDependencies": ["@testing-library/*", "jest-environment-jsdom"]
    },
    "packages/preset-eslint": {
      "entry": ["*.js"]
    },
    "packages/preset-typedoc": {
      "entry": ["*.js"]
    },
    "packages/preset-typescript": {
      "entry": ["*.json"]
    },
    "examples/*nextjs*": {
      "entry": ["src/app/**/{page.tsx,api/**/*.ts}"]
    },
    "examples/*": {
      "entry": ["src/main.{ts,tsx}"]
    },
    "apps/web-app": {
      "ignoreDependencies": ["cloudflare"]
    },
    "apps/*": {}
  }
}
