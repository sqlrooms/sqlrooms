{
  "name": "sqlrooms-web-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "build": "vite build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "deploy": "pnpm build && wrangler deploy",
    "dev": "vite dev --port 3000",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests --config vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^1.0.22",
    "@cloudflare/vite-plugin": "^1.26.0",
    "@neondatabase/auth": "0.4.1-beta",
    "@neondatabase/serverless": "^1.0.2",
    "@sqlrooms/ai": "workspace:*",
    "@sqlrooms/artifacts": "workspace:*",
    "@sqlrooms/db": "workspace:*",
    "@sqlrooms/documents": "workspace:*",
    "@sqlrooms/duckdb": "workspace:*",
    "@sqlrooms/layout": "workspace:*",
    "@sqlrooms/mosaic": "workspace:*",
    "@sqlrooms/room-store": "workspace:*",
    "@sqlrooms/sql-editor": "workspace:*",
    "@sqlrooms/sql-editor-config": "workspace:*",
    "@sqlrooms/ui": "workspace:*",
    "@sqlrooms/utils": "workspace:*",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "ai": "^6.0.154",
    "drizzle-orm": "^0.45.1",
    "jose": "^6.2.3",
    "lucide-react": "^0.555.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@tanstack/devtools-vite": "latest",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.36.0",
    "tailwindcss": "^4.1.18",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.44.1",
    "vite": "^8.0.5",
    "vitest": "^4.1.5",
    "wrangler": "^4.70.0"
  }
}
