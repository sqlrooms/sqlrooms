  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.13",
    "@types/node": "^20.19.17",
    "@types/react": "19.1.13",
    "@types/react-dom": "^19.1.9",
    "postcss": "^8.5.6",
