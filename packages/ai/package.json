{
  "name": "@sqlrooms/ai",
  "version": "0.29.0-rc.9",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sqlrooms/sqlrooms.git"
  },
  "license": "MIT",
  "author": "SQLRooms Contributors",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./devtools": {
      "types": "./dist/devtools.d.ts",
      "import": "./dist/devtools.js",
      "default": "./dist/devtools.js"
    }
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "lint": "eslint .",
    "test": "NODE_OPTIONS='--experimental-vm-modules --no-warnings' jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "typedoc": "typedoc"
  },
  "dependencies": {
    "@sqlrooms/ai-config": "workspace:*",
    "@sqlrooms/ai-core": "workspace:*",
    "@sqlrooms/ai-settings": "workspace:*",
    "@sqlrooms/data-table": "workspace:*",
    "@sqlrooms/duckdb": "workspace:*",
    "@sqlrooms/duckdb-core": "workspace:*",
    "@sqlrooms/room-shell": "workspace:*",
    "@sqlrooms/ui": "workspace:*",
    "ai": "^6.0.177",
    "immer": "^11.0.1",
    "lucide-react": "^0.556.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.0",
    "yaml": "^2.6.1",
    "zod": "^4.1.8",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "ts-jest": "^29.4.4"
  },
  "peerDependencies": {
    "apache-arrow": "17.0.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
