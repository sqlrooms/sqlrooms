  },
  "dependencies": {
    "@paralleldrive/cuid2": "^3.0.0",
    "@sqlrooms/cells": "workspace:*",
    "@sqlrooms/crdt": "workspace:*",
    "@sqlrooms/duckdb": "workspace:*",
    "@sqlrooms/room-store": "workspace:*",
    "@sqlrooms/ui": "workspace:*",
    "@sqlrooms/utils": "workspace:*",
    "@xyflow/react": "^12.8.5",
    "immer": "^11.0.1",
    "loro-mirror": "^1.1.2",
    "lucide-react": "^0.577.0",
    "zod": "^4.1.8"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
