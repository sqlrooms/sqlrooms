{
  "name": "@sqlrooms/canvas",
  "version": "0.29.0-rc.3",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sqlrooms/sqlrooms.git"
  },
  "license": "MIT",
  "author": "SQLRooms Contributors",
  "sideEffects": [
    "*.css"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./crdt": {
      "types": "./dist/crdt.d.ts",
      "import": "./dist/crdt.js"
    }
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
